# ── Backend ─────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=          # Mot de passe admin (obligatoire en production)

# ── Database (obligatoire sur Render pour garder les inscriptions) ──
DATABASE_URL=            # postgresql://user:pass@host:5432/db

# ── Dev local (optionnel) ───────────────────────────────────────
# Sans DATABASE_URL, les inscriptions sont stockées dans data/participants.json
# PORT=3001
